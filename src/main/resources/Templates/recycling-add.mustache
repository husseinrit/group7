<!DOCTYPE html>
<html>
<head>
    <title>Add Recycling Item</title>

    <style>
        body {
            font-family: Arial;
            background-color: lightgreen;
            text-align: center;
            padding: 60px;
        }

        .container {
            background-color: white;
            padding: 30px 50px;
            border-radius: 12px;
            display: inline-block;
            box-shadow: 2px 2px 10px gray;
        }

        input, select {
            padding: 8px;
            margin: 5px;
        }

        button {
            padding: 10px 20px;
            background-color: green;
            color: white;
            border: none;
        }

    </style>
</head>

<body>

<div class="container">

    <h1>Add Recycling Item</h1>

    <form action="/recycling/add" method="post">

        Item Name<br>
        <input name="itemName"><br><br>

        Category<br>
        <input name="category"><br><br>

        Recyclable<br>
        <select name="recyclable">
            <option value="true">Yes</option>
            <option value="false">No</option>
        </select>

        <br><br>

        <button type="submit">Add Item</button>

    </form>

    <br>

    <a href="/">Back to Home</a>

</div>

</body>
</html>