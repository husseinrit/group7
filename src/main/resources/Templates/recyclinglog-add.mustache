<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Add Recycling Log - Reloop</title>
    <style>
        body {
            font-family: 'Arial', sans-serif;
            background-color: lightgreen;
            color: darkgreen;
            text-align: center;
            padding: 60px;
        }
        h1 {
            color: green;
            font-size: 2.5rem;
            margin-bottom: 30px;
            text-shadow: 1px 1px lightgreen;
        }
        .container {
            background-color: white;
            padding: 40px 60px;
            border-radius: 12px;
            display: inline-block;
            box-shadow: 2px 2px 10px gray;
            text-align: left; /* Align form labels to the left */
            min-width: 400px;
        }
        label {
            display: block;
            font-weight: bold;
            margin-bottom: 5px;
            color: darkolivegreen;
        }
        input {
            width: 100%;
            padding: 10px;
            margin-bottom: 20px;
            border: 1px solid #ccc;
            border-radius: 6px;
            box-sizing: border-box; /* Ensures padding doesn't affect width */
        }
        button {
            background-color: green;
            color: white;
            padding: 12px 20px;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            width: 100%;
            font-size: 1.1rem;
            font-weight: bold;
        }
        button:hover {
            background-color: darkgreen;
        }
        .back-link {
            display: block;
            text-align: center;
            margin-top: 20px;
            color: darkgreen;
            text-decoration: none;
            font-weight: bold;
        }
        .back-link:hover {
            text-decoration: underline;
        }
    </style>
</head>
<body>
<div class="container">
    <h1>Add Recycling Log</h1>

    <form action="/recyclinglog/add" method="post">
        <label for="logId">Log ID:</label>
        <input type="number" name="logId" required>

        <label for="userId">User ID:</label>
        <input type="number" name="userId" required>

        <label for="itemId">Item ID:</label>