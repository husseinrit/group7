<!DOCTYPE html>
<html lang="en">
<body>
<h1>Add New User</h1>
<form method="post" action="/user/add">
    Full Name: <input name="fullName" required><br><br>
    Phone: <input name="phoneNumber" required><br><br>
    Age: <input name="age" type="number" required><br><br>
    City: <input name="city" required><br><br>
    Email: <input name="email" type="email" required><br><br>
    <button type="submit">Add User</button>
</form>
<a href="/">Home</a>
</body>
</html>
