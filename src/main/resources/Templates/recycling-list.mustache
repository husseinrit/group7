<!DOCTYPE html>
<html>
<head>
    <title>Recycling Items</title>

    <style>
        body {
            font-family: 'Arial', sans-serif;
            background-color: lightgreen;
            color: darkgreen;
            text-align: center;
            padding: 60px;
        }

        h1 {
            color: green;
            font-size: 2.5rem;
            margin-bottom: 40px;
            text-shadow: 1px 1px lightgreen;
        }

        .container {
            background-color: white;
            padding: 30px 50px;
            border-radius: 12px;
            display: inline-block;
            box-shadow: 2px 2px 10px gray;
        }

        table {
            border-collapse: collapse;
            margin: auto;
        }

        th, td {
            padding: 10px 20px;
            border: 1px solid gray;
        }

        a {
            color: darkgreen;
            font-weight: bold;
            text-decoration: none;
        }

    </style>
</head>

<body>

<div class="container">

    <h1>Recycling Items</h1>

    <table>

        <tr>
            <th>ID</th>
            <th>Name</th>
            <th>Category</th>
            <th>Recyclable</th>
        </tr>

        {{#items}}
            <tr>
                <td>{{itemId}}</td>
                <td>{{itemName}}</td>
                <td>{{category}}</td>
                <td>{{isRecyclable}}</td>
            </tr>
        {{/items}}

    </table>

    <br><br>

    <a href="/recycling/add">Add New Item</a>

    <br><br>

    <a href="/">Back to Home</a>

</div>

</body>
</html>