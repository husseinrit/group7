<!DOCTYPE html>
<html>
<head>
    <title>Success</title>

    <style>
        body {
            font-family: 'Arial', sans-serif;
            background-color: lightgreen;
            color: darkgreen;
            text-align: center;
            padding: 60px;
        }

        h1 {
            color: green;
            font-size: 2.5rem;
            margin-bottom: 30px;
        }

        .container {
            background-color: white;
            padding: 30px 50px;
            border-radius: 12px;
            display: inline-block;
            box-shadow: 2px 2px 10px gray;
        }

        p {
            font-size: 1.2rem;
        }

        a {
            color: darkgreen;
            font-weight: bold;
            text-decoration: none;
        }

        .button {
            display: inline-block;
            background-color: green;
            color: white;
            padding: 10px 20px;
            border-radius: 8px;
            text-decoration: none;
            margin-top: 20px;
        }

        .button:hover {
            background-color: darkgreen;
        }

    </style>
</head>

<body>

<div class="container">

    <h1>Success</h1>

    <p>Location added successfully!</p>

    <br>

    <a href="/locations" class="button">View Locations</a>

    <br><br>

    <a href="/">Back to Home</a>

</div>

</body>
</html>