<!DOCTYPE html>
<html lang="en">
<head><title>Users</title></head>
<body>
<h1>All Users</h1>
<table border="1">
    <tr>
        <th>Name</th><th>Phone</th><th>Age</th><th>City</th><th>Email</th>
    </tr>
    {{#users}}
        <tr>
            <td>{{fullName}}</td>
            <td>{{phoneNumber}}</td>
            <td>{{age}}</td>
            <td>{{city}}</td>
            <td>{{email}}</td>
        </tr>
    {{/users}}
</table>
<a href="/">Home</a>
</body>
</html>
